        "run":                ":RUN",
        "stop":               ":STOP",
        "single":             ":SINGle",
        "autoscale":          ":AUToscale",
        "channel_on":         ":CHANnel{ch}:DISPlay ON",
        "channel_off":        ":CHANnel{ch}:DISPlay OFF",
        "channel_scale":      {"write": ":CHANnel{ch}:SCALe {value}",       "query": ":CHANnel{ch}:SCALe?"},
        "channel_offset":     {"write": ":CHANnel{ch}:OFFSet {value}",      "query": ":CHANnel{ch}:OFFSet?"},
        "channel_coupling":   {"write": ":CHANnel{ch}:COUPling {coupling}", "query": ":CHANnel{ch}:COUPling?"},
        "channel_probe":      {"write": ":CHANnel{ch}:PROBe {attenuation}", "query": ":CHANnel{ch}:PROBe?"},
        "channel_label":      ":CHANnel{ch}:LABel \"{label}\"",
        "labels_on":          ":DISPlay:LABel ON",
        "labels_off":         ":DISPlay:LABel OFF",
        "annotation_text":    ":DISPlay:ANNotation:TEXT \"{text}\"",
        "annotation_on":      ":DISPlay:ANNotation ON",
        "annotation_off":     ":DISPlay:ANNotation OFF",
        "timebase_scale":     {"write": ":TIMebase:SCALe {value}",          "query": ":TIMebase:SCALe?"},
        "timebase_position":  {"write": ":TIMebase:POSition {value}",       "query": ":TIMebase:POSition?"},
        "trigger_source":     ":TRIGger:EDGE:SOURce CHANnel{ch}",
        "trigger_level":      {"write": ":TRIGger:EDGE:LEVel {value}",      "query": ":TRIGger:EDGE:LEVel?"},
        "trigger_slope":      {"write": ":TRIGger:EDGE:SLOPe {slope}",      "query": ":TRIGger:EDGE:SLOPe?"},
        "measure_vpp":        {"query": ":MEASure:VPP? CHANnel{ch}"},
        "measure_freq":       {"query": ":MEASure:FREQuency? CHANnel{ch}"},
        "measure_period":     {"query": ":MEASure:PERiod? CHANnel{ch}"},
        "measure_vavg":       {"query": ":MEASure:VAVerage? CHANnel{ch}"},
        "measure_vrms":       {"query": ":MEASure:VRMS? CHANnel{ch}"},
        "measure_vmax":       {"query": ":MEASure:VMAX? CHANnel{ch}"},
        "measure_vmin":       {"query": ":MEASure:VMIN? CHANnel{ch}"},
        "measure_risetime":   {"query": ":MEASure:RISetime? CHANnel{ch}"},
        "measure_falltime":   {"query": ":MEASure:FALLtime? CHANnel{ch}"},
        "measure_dutycycle":  {"query": ":MEASure:DUTYcycle? CHANnel{ch}"},
        "screenshot":         {"raw_query": ":DISPlay:DATA? PNG,COLor"}
      }
    },

